<Window x:Class="NorthLog.Wpf.Views.LegacyReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Legacy Reports" Height="600" Width="800"
        Background="#EEEEEE">

    <!-- To the interviewer:
         I've left every colour, font and margin hardcoded, and not a single
         control bound to a ViewModel. All logic is in the .cs code-behind,
         a WPF equivalent of a god controller. Compare with
         MainWindow.xaml — the contrast is the point. -->

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Text="Wellbore:" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center" />
            <ComboBox x:Name="cmbWellbore" Width="300" SelectionChanged="cmbWellbore_SelectionChanged" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,10,0,0">
            <!-- No labels associated with TextBoxes. Try navigating this with a screen reader. -->
            <TextBox x:Name="txtDate"      Width="90"  Margin="0,0,5,0" />
            <TextBox x:Name="txtDepthIn"   Width="70"  Margin="0,0,5,0" />
            <TextBox x:Name="txtDepthOut"  Width="70"  Margin="0,0,5,0" />
            <TextBox x:Name="txtOil"       Width="60"  Margin="0,0,5,0" />
            <TextBox x:Name="txtLithology" Width="200" Margin="0,0,5,0" />
            <TextBox x:Name="txtNotes"     Width="200" Margin="0,0,5,0" />
            <Button  Content="SUBMIT" Background="#FFCC00" Foreground="Black"
                     Padding="10,3" Click="Submit_Click" />
        </StackPanel>

        <DataGrid x:Name="grid" Grid.Row="2" Margin="0,10,0,0" />

        <TextBlock x:Name="txtStatus" Grid.Row="3" Foreground="Red" Margin="0,5,0,0" />
    </Grid>
</Window>