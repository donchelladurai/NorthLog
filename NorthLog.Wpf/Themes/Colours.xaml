<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ColorBg">#F4F5F7</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorBorder">#D0D5DD</Color>
    <Color x:Key="ColorText">#101828</Color>
    <Color x:Key="ColorMuted">#475467</Color>
    <Color x:Key="ColorAccent">#0B6E99</Color>
    <Color x:Key="ColorDanger">#B42318</Color>

    <SolidColorBrush x:Key="BgBrush"      Color="{StaticResource ColorBg}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BorderBrush"  Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="TextBrush"    Color="{StaticResource ColorText}" />
    <SolidColorBrush x:Key="MutedBrush"   Color="{StaticResource ColorMuted}" />
    <SolidColorBrush x:Key="AccentBrush"  Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="DangerBrush"  Color="{StaticResource ColorDanger}" />

    <Style TargetType="TextBlock" x:Key="LabelText">
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,8,0,2" />
    </Style>

    <Style TargetType="TextBlock" x:Key="HeadingText">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

</ResourceDictionary>